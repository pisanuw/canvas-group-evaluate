# Copy this file to .env and fill in your own values.
# .env is git-ignored; .env.example is committed as a template.

# Path to a file containing your Canvas API access token (one line, no quotes).
# Generate one at https://<your-canvas-host>/profile/settings under
# "Approved Integrations" > "New Access Token".
CANVAS_TOKEN_PATH=/path/to/token-canvas.txt

# Canvas API base URL for your institution.
# Examples:
#   https://canvas.uw.edu/api/v1
#   https://canvas.instructure.com/api/v1
CANVAS_BASE=https://canvas.uw.edu/api/v1

# Default Canvas course id. Read from the URL: /courses/<id>/
# Can be overridden per-run with --course on the command line.
DEFAULT_COURSE=1902104

# Default Canvas group-category id (a.k.a. group set).
# Read from the URL fragment on the groups page: /courses/<id>/groups#tab-<group_category_id>
# Can be overridden per-run with --group-category on the command line.
DEFAULT_GROUP_CATEGORY=231120
